# =============================================================================
# Build-time / SSR
# =============================================================================
# Public site URL — used for Stripe success/cancel redirects and canonical tags.
# Set to https://nbmecalc.com in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# Stripe (server only — never expose to client)
# =============================================================================
# Test mode keys start with sk_test_ / pk_test_ — get them at:
#   https://dashboard.stripe.com/test/apikeys
# Switch to live keys (sk_live_*) only after end-to-end testing in test mode.
STRIPE_SECRET_KEY=
# Optional: publishable key, only needed if we later add client-side Stripe.js.
# Safe to expose in NEXT_PUBLIC_*.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Webhook signing secret — get from:
#   https://dashboard.stripe.com/test/webhooks  (create endpoint first)
# In local dev, use `stripe listen --forward-to localhost:3000/api/webhook`
# and copy the whsec_* it prints.
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — create the Products + Prices in the Stripe dashboard,
# then paste their `price_*` IDs here. We never hard-code prices in source.
#   Single Report: $14.99 one-time
STRIPE_PRICE_SINGLE=
#   Pro Monthly: $9.99/mo recurring (used in C2-B)
STRIPE_PRICE_PRO_MONTHLY=
#   Pro Annual:  $79/yr recurring  (used in C2-B)
STRIPE_PRICE_PRO_ANNUAL=

# =============================================================================
# Email (Postal HTTP API — server only)
# =============================================================================
# Cloudflare Workers can't open raw TCP sockets, so we call Postal's HTTP API
# instead of SMTP. Get the API credential from your Postal dashboard:
#   Org → Mail Server → Credentials → New Credential (type: API)
POSTAL_API_URL=https://mail.removexif.com/api/v1/send/message
POSTAL_API_KEY=
# Verified sender address on your Postal mail server.
SMTP_FROM=noreply@nbmecalc.com

# Legacy SMTP vars (kept for any non-Edge tooling, e.g. local scripts). Unused
# in production runtime now that we send via the Postal HTTP API above.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# =============================================================================
# PDF renderer Worker (server only)
# =============================================================================
PDF_RENDERER_URL=https://nbmecalc.com/api/_pdf-renderer
PDF_RENDERER_SECRET=

# =============================================================================
# Image generation (offline script — not needed at runtime)
# =============================================================================
# Evolink.ai Z Image Turbo API
# Get your key at: https://evolink.ai/dashboard/keys
EVOLINK_API_KEY=

# =============================================================================
# Google OAuth (server only — never expose to client)
# =============================================================================
# Get these by creating an OAuth 2.0 Client ID in Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials
# Required redirect URIs to register on the Google side:
#   https://nbmecalc.com/api/auth/google/callback   (production)
#   http://localhost:3000/api/auth/google/callback  (local dev)
# In production, set these via `wrangler pages secret put GOOGLE_CLIENT_ID`
# and `wrangler pages secret put GOOGLE_CLIENT_SECRET`.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
