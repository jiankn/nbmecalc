{
  "name": "nbmecalc",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "gen:images": "node scripts/gen-images.mjs",
    "gen:images:force": "node scripts/gen-images.mjs --force",
    "pages:build": "npx @cloudflare/next-on-pages",
    "preview": "npm run pages:build && npx wrangler pages dev .vercel/output/static --compatibility-flags=nodejs_compat",
    "deploy": "npm run pages:build && npx wrangler pages deploy .vercel/output/static --project-name=nbmecalc",
    "deploy:pdf-worker": "npx wrangler deploy --config workers/pdf-renderer/wrangler.toml",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cloudflare/puppeteer": "^1.0.6",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@react-pdf/renderer": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.16.0",
    "next": "15.1.4",
    "nodemailer": "^8.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^22.1.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20260518.1",
    "@types/node": "^22",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "vitest": "^4.1.6",
    "wrangler": "^4.92.0"
  }
}
